# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
AUTH_ENABLED=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Login IP rate limit
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX=15

# Account lockout after wrong passwords
ACCOUNT_LOCK_MAX_FAILED_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=5

# Upload IP rate limits
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=1
UPLOAD_RATE_LIMIT_MAX=30
PUBLIC_UPLOAD_RATE_LIMIT_WINDOW_MINUTES=60
PUBLIC_UPLOAD_RATE_LIMIT_MAX=10

# Protected media token behavior
MEDIA_TOKEN_DYNAMIC_EXPIRY=true
MEDIA_TOKEN_EXPIRES_MIN=10

# Lightsail/S3 storage
AWS_REGION=ap-south-1
AWS_S3_BUCKET=studio-webzspot
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
